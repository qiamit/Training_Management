rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /certificates/{userId}/{fileName} {
      allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.token.role == 'super_admin');
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /organizations/{orgId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.role in ['super_admin', 'tenant_admin', 'quality_manager'];
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
